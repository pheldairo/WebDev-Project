{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "University Schedule API",
    "description": "Complete API collection for the real-time collaborative university schedule system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "room_code", "value": "", "type": "string" },
    { "key": "room_id", "value": "", "type": "string" },
    { "key": "entry_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access);",
                  "pm.collectionVariables.set('refresh_token', json.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access);",
                  "pm.collectionVariables.set('refresh_token', json.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/profile/", "host": ["{{base_url}}"], "path": ["api", "auth", "profile", ""] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"semester\": 3,\n  \"major\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/profile/", "host": ["{{base_url}}"], "path": ["api", "auth", "profile", ""] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/logout/", "host": ["{{base_url}}"], "path": ["api", "auth", "logout", ""] }
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "List My Rooms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/rooms/", "host": ["{{base_url}}"], "path": ["api", "rooms", ""] }
          }
        },
        {
          "name": "Create Room",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Study Group\",\n  \"password\": \"room123\",\n  \"category\": \"UNIVERSITY\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/rooms/create/", "host": ["{{base_url}}"], "path": ["api", "rooms", "create", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('room_code', json.code);",
                  "pm.collectionVariables.set('room_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Join Room",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{room_code}}\",\n  \"password\": \"room123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/rooms/join/", "host": ["{{base_url}}"], "path": ["api", "rooms", "join", ""] }
          }
        }
      ]
    },
    {
      "name": "University",
      "item": [
        {
          "name": "List Academic Slots",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/university/slots/", "host": ["{{base_url}}"], "path": ["api", "university", "slots", ""] }
          }
        }
      ]
    },
    {
      "name": "Schedule",
      "item": [
        {
          "name": "List Schedule Entries",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/schedule/?room={{room_id}}", "host": ["{{base_url}}"], "path": ["api", "schedule", ""], "query": [{ "key": "room", "value": "{{room_id}}" }] }
          }
        },
        {
          "name": "Confirm Academic Selection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room\": {{room_id}},\n  \"slots\": [1, 2, 3]\n}"
            },
            "url": { "raw": "{{base_url}}/api/schedule/confirm-selection/", "host": ["{{base_url}}"], "path": ["api", "schedule", "confirm-selection", ""] }
          }
        },
        {
          "name": "Create Manual Entry (Note)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Buy groceries\",\n  \"teacher\": \"Me\",\n  \"day\": \"MON\",\n  \"time_slot\": \"18:00-19:00\",\n  \"room\": {{room_id}},\n  \"description\": \"Must buy milk\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/schedule/", "host": ["{{base_url}}"], "path": ["api", "schedule", ""] }
          }
        },
        {
          "name": "Get Schedule Entry",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/schedule/{{entry_id}}/", "host": ["{{base_url}}"], "path": ["api", "schedule", "{{entry_id}}", ""] }
          }
        },
        {
          "name": "Update Entry",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"is_private\": true\n}" },
            "url": { "raw": "{{base_url}}/api/schedule/{{entry_id}}/", "host": ["{{base_url}}"], "path": ["api", "schedule", "{{entry_id}}", ""] }
          }
        },
        {
          "name": "Delete Entry",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/schedule/{{entry_id}}/", "host": ["{{base_url}}"], "path": ["api", "schedule", "{{entry_id}}", ""] }
          }
        }
      ]
    }
  ]
}
