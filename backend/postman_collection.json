{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "University Schedule API",
    "description": "Complete API collection for the real-time collaborative university schedule system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access);",
                  "pm.collectionVariables.set('refresh_token', json.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access);",
                  "pm.collectionVariables.set('refresh_token', json.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/logout/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "Create Room",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Computer Science - Section A\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rooms/create/",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "create", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('room_code', json.code);",
                  "pm.collectionVariables.set('room_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Join Room",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{room_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rooms/join/",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms", "join", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Schedule",
      "item": [
        {
          "name": "List Schedule Entries",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedule/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", ""]
            }
          }
        },
        {
          "name": "List Schedule Entries by Room",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedule/?room={{room_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", ""],
              "query": [
                { "key": "room", "value": "{{room_id}}" }
              ]
            }
          }
        },
        {
          "name": "Create Schedule Entry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Mathematics\",\n  \"teacher\": \"Dr. Smith\",\n  \"day\": \"MON\",\n  \"time_slot\": \"08:00-10:00\",\n  \"room\": {{room_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schedule/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('entry_id', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Schedule Entry",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedule/{{entry_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", "{{entry_id}}", ""]
            }
          }
        },
        {
          "name": "Update Schedule Entry (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Advanced Mathematics\",\n  \"teacher\": \"Dr. Johnson\",\n  \"day\": \"MON\",\n  \"time_slot\": \"08:00-10:00\",\n  \"room\": {{room_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schedule/{{entry_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", "{{entry_id}}", ""]
            }
          }
        },
        {
          "name": "Partial Update Schedule Entry (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacher\": \"Prof. Williams\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schedule/{{entry_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", "{{entry_id}}", ""]
            }
          }
        },
        {
          "name": "Delete Schedule Entry",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedule/{{entry_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", "{{entry_id}}", ""]
            }
          }
        },
        {
          "name": "My Schedule Entries",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedule/mine/",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", "mine", ""]
            }
          }
        }
      ]
    }
  ]
}
